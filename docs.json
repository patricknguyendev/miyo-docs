{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Miyo Help Center",
  "description": "Practical guides for managing money on your own or with your household in Miyo.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#8B5CF6"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "icon": "house",
        "pages": [
          "index",
          "getting-started/quickstart",
          "getting-started/navigate-miyo",
          "getting-started/choose-your-first-data-path"
        ]
      },
      {
        "group": "Accounts",
        "icon": "landmark",
        "pages": [
          "accounts/connect-and-manage-accounts",
          "accounts/connect-a-bank",
          "accounts/add-a-manual-account",
          "accounts/manage-linked-institutions"
        ]
      },
      {
        "group": "Transactions",
        "icon": "receipt-text",
        "pages": [
          "transactions/manage-transactions",
          "transactions/review-and-categorize",
          "settings/categories",
          "settings/transaction-rules",
          "transactions/import-transactions",
          "transactions/import-a-csv"
        ]
      },
      {
        "group": "Budget and goals",
        "icon": "wallet-cards",
        "pages": [
          "budgets/overview",
          "budgets/choose-budget-mode",
          "budgets/create-and-manage-budget",
          "planning/monthly-budget",
          "budgets/category-targets",
          "planning/category-targets",
          "planning/funding-styles",
          "goals/create-savings-goal",
          "planning/savings-goals"
        ]
      },
      {
        "group": "Insights and payoff",
        "icon": "chart-no-axes-combined",
        "pages": [
          "insights/spending-and-reports",
          "recurring/review-recurring",
          "insights/recurring-payments",
          "debt/debt-workspace",
          "insights/debt-payoff"
        ]
      },
      {
        "group": "Household and privacy",
        "icon": "users",
        "pages": [
          "household/setup-household",
          "households/invite-a-partner",
          "household/account-visibility",
          "households/privacy-controls",
          "privacy/privacy-center",
          "household/money-date"
        ]
      },
      {
        "group": "Account and security",
        "icon": "shield-check",
        "pages": [
          "settings/security-and-mfa",
          "account/secure-your-account",
          "settings/notifications",
          "account/manage-your-data"
        ]
      },
      {
        "group": "Troubleshooting and support",
        "icon": "life-buoy",
        "pages": [
          "support/troubleshooting",
          "troubleshooting/bank-sync",
          "troubleshooting/imports-and-duplicates",
          "support/faq",
          "support/contact",
          "support/contact-support"
        ]
      },
      {
        "group": "What's new",
        "icon": "megaphone",
        "pages": [
          "changelog"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Miyo",
          "href": "https://joinmiyo.com",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Privacy",
          "href": "https://joinmiyo.com/privacy",
          "icon": "shield"
        }
      ]
    }
  },
  "redirects": [
    {
      "source": "/goals/funding-styles",
      "destination": "/planning/funding-styles"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Contact support",
        "href": "/support/contact-support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Miyo",
      "href": "https://joinmiyo.com/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/patricknguyendev/MiyoWeb"
    },
    "links": [
      {
        "header": "Miyo",
        "items": [
          {
            "label": "Open dashboard",
            "href": "https://joinmiyo.com/dashboard"
          },
          {
            "label": "Pricing",
            "href": "https://joinmiyo.com/pricing"
          }
        ]
      },
      {
        "header": "Trust",
        "items": [
          {
            "label": "Privacy policy",
            "href": "https://joinmiyo.com/privacy"
          },
          {
            "label": "Terms of service",
            "href": "https://joinmiyo.com/terms"
          }
        ]
      },
      {
        "header": "Support",
        "items": [
          {
            "label": "Contact support",
            "href": "/support/contact-support"
          },
          {
            "label": "Troubleshooting",
            "href": "/support/troubleshooting"
          }
        ]
      }
    ]
  },
  "seo": {
    "indexing": "all"
  }
}
