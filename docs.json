{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Miyo Help Center",
  "description": "Practical guides for managing your money privately with Miyo.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "favicon": "/logo/miyo-mark.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "icon": "house",
        "pages": [
          "index",
          "getting-started/quickstart",
          "getting-started/choose-your-first-data-path"
        ]
      },
      {
        "group": "Accounts",
        "icon": "landmark",
        "pages": [
          "accounts/connect-a-bank",
          "accounts/add-a-manual-account",
          "accounts/manage-linked-institutions"
        ]
      },
      {
        "group": "Transactions",
        "icon": "receipt-text",
        "pages": [
          "transactions/review-and-categorize",
          "transactions/import-a-csv"
        ]
      },
      {
        "group": "Plan your money",
        "icon": "wallet-cards",
        "pages": [
          "planning/monthly-budget",
          "planning/category-targets",
          "planning/funding-styles",
          "planning/savings-goals"
        ]
      },
      {
        "group": "Understand your money",
        "icon": "chart-no-axes-combined",
        "pages": [
          "insights/spending-and-reports",
          "insights/recurring-payments",
          "insights/debt-payoff"
        ]
      },
      {
        "group": "Households and privacy",
        "icon": "users",
        "pages": [
          "households/invite-a-partner",
          "households/privacy-controls"
        ]
      },
      {
        "group": "Account and security",
        "icon": "shield-check",
        "pages": [
          "account/secure-your-account",
          "account/manage-your-data"
        ]
      },
      {
        "group": "Troubleshooting",
        "icon": "life-buoy",
        "pages": [
          "troubleshooting/bank-sync",
          "troubleshooting/imports-and-duplicates",
          "support/contact-support"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Miyo",
          "href": "https://joinmiyo.com",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Privacy",
          "href": "https://joinmiyo.com/privacy",
          "icon": "shield"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact support",
        "href": "/support/contact-support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Miyo",
      "href": "https://joinmiyo.com/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/patricknguyendev/MiyoWeb"
    }
  },
  "seo": {
    "indexing": "all"
  }
}
